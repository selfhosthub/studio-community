{
  "$schema": "https://raw.githubusercontent.com/selfhosthub/studio-community/main/schemas/provider-config.schema.json",
  "name": "Leonardo AI",
  "slug": "leonardo",
  "description": "AI-powered image generation with Leonardo",
  "category": "ai",
  "provider_type": "API",
  "icon_url": "/providers/leonardo.svg",
  "default_queue": "step_jobs",
  "auth": {
    "type": "api_key",
    "config": {
      "header": "Authorization",
      "prefix": "Bearer"
    }
  },
  "credential_schema": {
    "type": "object",
    "required": [
      "api_key"
    ],
    "properties": {
      "api_key": {
        "type": "string",
        "title": "API Key",
        "description": "Leonardo API key from dashboard",
        "format": "password"
      }
    }
  },
  "services": {
    "text_to_image": {
      "display_name": "Text to Image",
      "description": "Generate images from text prompts. Waits for completion (10-60s typical).",
      "service_type": "AI",
      "endpoint": "/generations",
      "method": "POST",
      "requires_credentials": true,
      "parameterMapping": {
        "body": [
          "prompt",
          "width",
          "height",
          "num_images",
          "modelId",
          "public",
          "tiling",
          "transparency",
          "unzoom",
          "alchemy",
          "nsfw",
          "weighting",
          "canvasRequest",
          "highContrast",
          "highResolution",
          "negative_prompt",
          "promptMagic",
          "promptMagicVersion",
          "promptMagicStrength",
          "enhancePrompt",
          "guidance_scale",
          "scheduler",
          "seed",
          "num_inference_steps",
          "init_image_id",
          "init_strength",
          "sdVersion",
          "photoReal",
          "photoRealVersion",
          "photoRealStrength",
          "expandedDomain",
          "fantasyAvatar",
          "ultra",
          "presetStyle",
          "contrast",
          "controlnets",
          "imagePrompts",
          "upscaleRatio",
          "generationTimeout"
        ]
      },
      "parameter_schema": {
        "type": "object",
        "required": [
          "prompt",
          "width",
          "height",
          "num_images",
          "modelId"
        ],
        "properties": {
          "prompt": {
            "type": "string",
            "title": "Prompt",
            "description": "Text description of the image to generate",
            "minLength": 1,
            "maxLength": 1000,
            "ui": {
              "section": "basic",
              "order": 1,
              "widget": "textarea",
              "rows": 4
            }
          },
          "width": {
            "type": "integer",
            "title": "Width",
            "description": "Image width in pixels",
            "default": 1024,
            "enum": [
              512,
              576,
              768,
              1024,
              1280,
              1536,
              2048
            ],
            "multipleOf": 8,
            "ui": {
              "section": "basic",
              "order": 2
            }
          },
          "height": {
            "type": "integer",
            "title": "Height",
            "description": "Image height in pixels",
            "default": 576,
            "enum": [
              512,
              576,
              768,
              1024,
              1280,
              1536,
              2048
            ],
            "multipleOf": 8,
            "ui": {
              "section": "basic",
              "order": 3
            }
          },
          "num_images": {
            "type": "integer",
            "title": "Number of Images",
            "description": "Number of images to generate (API default: 4 if omitted)",
            "minimum": 1,
            "maximum": 8,
            "default": 4,
            "initialValue": 1,
            "ui": {
              "section": "basic",
              "order": 4
            }
          },
          "modelId": {
            "type": "string",
            "title": "Model",
            "description": "Leonardo AI model to use for generation",
            "default": "1e60896f-3c26-4296-8ecc-53e2afecc132",
            "enum": [
              "e316348f-7773-490e-adcd-46757c738eb7",
              "2067ae52-33fd-4a82-bb92-c2c55e7d2786",
              "ff883b60-9040-4c18-8d4e-ba7522c6b71d",
              "1aa0f478-51be-4efd-94e8-76bfc8f533af",
              "47a6232a-1d49-4c95-83c3-2cc5342f82c7",
              "6c95de60-a0bc-4f90-b637-ee8971caf3b0",
              "302e258f-29b5-4dd8-9a7c-0cd898cb2143",
              "4b2e0f95-f15e-48d8-ada3-c071d6104db8",
              "102a8ee0-cf16-477c-8477-c76963a0d766",
              "5fce4543-8e23-4b77-9c3f-202b3f1c211e",
              "6908bfaf-8cf2-4fda-8c46-03f892d82e06",
              "50c4f43b-f086-4838-bcac-820406244cec",
              "458ecfff-f76c-402c-8b85-f09f6fb198de",
              "f3296a34-9aef-4370-ad18-88daf26862c3",
              "d2fb9cf9-7999-4ae5-8bfe-f0df2d32abf8",
              "b7aa9939-abed-4d4e-96c4-140b8c65dd92",
              "ac614f96-1082-45bf-be9d-757f2d31c174",
              "756be0a8-38b1-4946-ad62-c0ac832422e3",
              "ab200606-5d09-4e1e-9050-0b05b839e944",
              "7a65f0ab-64a7-4be2-bcf3-64a1cc56f627",
              "e71a1c2f-4f80-4800-934f-2c68979d8cc8",
              "6bef9f1b-29cb-40c7-b9df-32b51c1f67d3",
              "b820ea11-02bf-4652-97ae-9ac0cc00593d",
              "1e60896f-3c26-4296-8ecc-53e2afecc132",
              "aa77f04e-3eec-4034-9c07-d0f619684628",
              "b24e16ff-06e3-43eb-8d33-4416c2d75876",
              "6b645e3a-d64f-4341-a6d8-7a3690fbf042",
              "cd2b2a15-9760-4174-a5ff-4d2925057376",
              "291be633-cb24-434f-898f-e662799936ad",
              "5c232a9e-9061-4777-980a-ddc8e65647c6",
              "2d18c0af-374e-4391-9ca2-639f59837c85",
              "45ab2421-87de-44c8-a07c-3b87e3bfdf84",
              "e5a291b6-3990-495a-b1fa-7bd1864510a6",
              "a097c2df-8f0c-4029-ae0f-8fd349055e61",
              "f1929ea3-b169-4c18-a16c-5d58b4292c69",
              "b63f7119-31dc-4540-969b-2a9df997e173",
              "16e7060a-803e-4df3-97ee-edcfa5dc9cc8",
              "ee0fc1a3-aacb-48bf-9234-ada3cc02748f",
              "5fdadebb-17ae-472c-bf76-877e657f97de",
              "17e4edbf-690b-425d-a466-53c816f0de8a"
            ],
            "enumNames": [
              "Absolute Reality v1.6",
              "AlbedoBase XL",
              "Amulets",
              "Anime Pastel Dream",
              "Battle Axes",
              "Character Portraits",
              "Chest Armor",
              "Christmas Stickers",
              "Crystal Deposits",
              "Crystal Deposits Alternate",
              "Cute Animal Characters",
              "Cute Characters",
              "Deliberate 1.1",
              "DreamShaper 3.2",
              "DreamShaper v5",
              "DreamShaper v6",
              "DreamShaper v7",
              "Isometric Asteroid Tiles",
              "Isometric Fantasy",
              "Isometric Scifi Buildings",
              "Leonardo Anime XL",
              "Leonardo Creative",
              "Leonardo Diffusion",
              "Leonardo Diffusion XL",
              "Leonardo Kino XL",
              "Leonardo Lightning XL",
              "Leonardo Phoenix",
              "Leonardo Select",
              "Leonardo Signature",
              "Leonardo Vision XL",
              "Magic Items",
              "Magic Potions",
              "Pixel Art",
              "RPG 4.0",
              "RPG v5",
              "SDXL 0.9",
              "SDXL 1.0",
              "Shields",
              "Spirit Creatures",
              "Vintage Style Photography"
            ],
            "ui": {
              "section": "basic",
              "order": 5
            }
          },
          "public": {
            "type": "boolean",
            "title": "Make Public",
            "description": "Make generation publicly visible",
            "default": false,
            "ui": {
              "section": "image_options",
              "order": 1
            }
          },
          "tiling": {
            "type": "boolean",
            "title": "Tiling",
            "description": "Generate tileable/seamless images",
            "default": false,
            "ui": {
              "section": "image_options",
              "order": 2
            }
          },
          "transparency": {
            "type": "string",
            "title": "Transparency",
            "description": "Type of transparency for the image",
            "enum": [
              "disabled",
              "foreground_only"
            ],
            "enumNames": [
              "Disabled",
              "Foreground Only"
            ],
            "ui": {
              "section": "image_options",
              "order": 3
            }
          },
          "unzoom": {
            "type": "boolean",
            "title": "Enable Unzoom",
            "description": "Enable unzoom feature",
            "default": false,
            "ui": {
              "section": "image_options",
              "order": 4
            }
          },
          "alchemy": {
            "type": "boolean",
            "title": "Alchemy",
            "description": "Enable Alchemy refiner for high-fidelity generation",
            "default": false,
            "ui": {
              "section": "image_options",
              "order": 5
            }
          },
          "nsfw": {
            "type": "boolean",
            "title": "NSFW Filter",
            "description": "Enable NSFW content filter",
            "default": true,
            "ui": {
              "section": "image_options",
              "order": 6
            }
          },
          "weighting": {
            "type": "number",
            "title": "Weighting",
            "description": "Weighting value for generation",
            "minimum": 0,
            "maximum": 1,
            "ui": {
              "section": "image_options",
              "order": 7
            }
          },
          "canvasRequest": {
            "type": "boolean",
            "title": "Canvas Request",
            "description": "Enable canvas request mode",
            "default": false,
            "ui": {
              "section": "image_options",
              "order": 8
            }
          },
          "highContrast": {
            "type": "boolean",
            "title": "High Contrast",
            "description": "Enable high contrast mode",
            "default": false,
            "ui": {
              "section": "image_options",
              "order": 9
            }
          },
          "highResolution": {
            "type": "boolean",
            "title": "High Resolution",
            "description": "Enable high resolution mode",
            "default": false,
            "ui": {
              "section": "image_options",
              "order": 10
            }
          },
          "negative_prompt": {
            "type": "string",
            "title": "Negative Prompt",
            "description": "Things to avoid in the generated image",
            "maxLength": 1000,
            "ui": {
              "section": "prompt_engineering",
              "order": 1,
              "widget": "textarea",
              "rows": 3
            }
          },
          "promptMagic": {
            "type": "boolean",
            "title": "Enable Prompt Magic",
            "description": "Enable Prompt Magic for better prompt adherence",
            "default": false,
            "ui": {
              "section": "prompt_engineering",
              "order": 2
            }
          },
          "promptMagicVersion": {
            "type": "string",
            "title": "Prompt Magic Version",
            "description": "Version of Prompt Magic (only used when Prompt Magic is enabled)",
            "enum": [
              "v2",
              "v3"
            ],
            "ui": {
              "section": "prompt_engineering",
              "order": 3,
              "show_when": {
                "promptMagic": "true"
              }
            }
          },
          "promptMagicStrength": {
            "type": "number",
            "title": "Prompt Magic Strength",
            "description": "Strength of Prompt Magic effect (only used when Prompt Magic is enabled)",
            "minimum": 0.1,
            "maximum": 1.0,
            "ui": {
              "section": "prompt_engineering",
              "order": 4,
              "show_when": {
                "promptMagic": "true"
              }
            }
          },
          "enhancePrompt": {
            "type": "boolean",
            "title": "Enhance Prompt",
            "description": "Automatically enhance the prompt with more detail",
            "default": false,
            "ui": {
              "section": "prompt_engineering",
              "order": 5
            }
          },
          "guidance_scale": {
            "type": "number",
            "title": "Guidance Scale",
            "description": "How closely to follow the prompt (CFG scale, 1-20)",
            "default": 7,
            "minimum": 1,
            "maximum": 20,
            "ui": {
              "section": "generation_params",
              "order": 1
            }
          },
          "scheduler": {
            "type": "string",
            "title": "Scheduler",
            "description": "Sampling scheduler algorithm",
            "enum": [
              "KLMS",
              "EULER_ANCESTRAL_DISCRETE",
              "EULER_DISCRETE",
              "DDIM",
              "DPM_SOLVER",
              "PNDM"
            ],
            "enumNames": [
              "KLMS",
              "Euler Ancestral",
              "Euler",
              "DDIM",
              "DPM Solver",
              "PNDM"
            ],
            "default": "EULER_DISCRETE",
            "ui": {
              "section": "generation_params",
              "order": 2
            }
          },
          "seed": {
            "type": "integer",
            "title": "Seed",
            "description": "Random seed for reproducibility (leave empty for random)",
            "minimum": 0,
            "maximum": 2147483647,
            "ui": {
              "section": "generation_params",
              "order": 3
            }
          },
          "num_inference_steps": {
            "type": "integer",
            "title": "Inference Steps",
            "description": "Number of denoising steps (higher = better quality, slower)",
            "default": 30,
            "minimum": 10,
            "maximum": 60,
            "ui": {
              "section": "generation_params",
              "order": 4
            }
          },
          "init_image_id": {
            "type": "string",
            "title": "Init Image ID",
            "description": "ID of the initialization image for img2img",
            "ui": {
              "section": "img2img",
              "order": 1
            }
          },
          "init_strength": {
            "type": "number",
            "title": "Init Strength",
            "description": "How much the init image influences the result (0 = ignore, 1 = exact copy)",
            "minimum": 0,
            "maximum": 1,
            "ui": {
              "section": "img2img",
              "order": 2
            }
          },
          "sdVersion": {
            "type": "string",
            "title": "SD Version",
            "description": "Stable Diffusion version to use",
            "enum": [
              "v1_5",
              "v2",
              "v2_1",
              "SDXL_0_8",
              "SDXL_0_9",
              "SDXL_1_0",
              "SDXL_LIGHTNING"
            ],
            "enumNames": [
              "v1.5",
              "v2",
              "v2.1",
              "SDXL 0.8",
              "SDXL 0.9",
              "SDXL 1.0",
              "SDXL Lightning"
            ],
            "ui": {
              "section": "additional",
              "order": 1
            }
          },
          "photoReal": {
            "type": "boolean",
            "title": "PhotoReal",
            "description": "Enable PhotoReal feature (requires Alchemy)",
            "default": false,
            "ui": {
              "section": "additional",
              "order": 2
            }
          },
          "photoRealVersion": {
            "type": "string",
            "title": "PhotoReal Version",
            "description": "Version of PhotoReal to use",
            "enum": [
              "v1",
              "v2"
            ],
            "ui": {
              "section": "additional",
              "order": 3,
              "show_when": {
                "photoReal": "true"
              }
            }
          },
          "photoRealStrength": {
            "type": "number",
            "title": "PhotoReal Strength",
            "description": "Strength of PhotoReal effect (only used when PhotoReal is enabled)",
            "minimum": 0.1,
            "maximum": 1.0,
            "ui": {
              "section": "additional",
              "order": 4,
              "show_when": {
                "photoReal": "true"
              }
            }
          },
          "expandedDomain": {
            "type": "boolean",
            "title": "Expanded Domain",
            "description": "Enable expanded domain for wider range of outputs",
            "default": false,
            "ui": {
              "section": "additional",
              "order": 5
            }
          },
          "fantasyAvatar": {
            "type": "boolean",
            "title": "Fantasy Avatar",
            "description": "Enable fantasy avatar mode",
            "default": false,
            "ui": {
              "section": "additional",
              "order": 6
            }
          },
          "ultra": {
            "type": "boolean",
            "title": "Ultra",
            "description": "Enable ultra quality mode (cannot be used with Alchemy)",
            "default": false,
            "ui": {
              "section": "additional",
              "order": 7
            }
          },
          "presetStyle": {
            "type": "string",
            "title": "Preset Style",
            "description": "Leonardo preset style for image generation (SDXL Models Only)",
            "enum": [
              "LEONARDO",
              "ANIME",
              "CREATIVE",
              "DYNAMIC",
              "ENVIRONMENT",
              "GENERAL",
              "ILLUSTRATION",
              "PHOTOGRAPHY",
              "RAYTRACED",
              "RENDER_3D",
              "SKETCH_BW",
              "SKETCH_COLOR",
              "NONE"
            ],
            "enumNames": [
              "Leonardo",
              "Anime",
              "Creative",
              "Dynamic",
              "Environment",
              "General",
              "Illustration",
              "Photography",
              "Raytraced",
              "3D Render",
              "Sketch (B&W)",
              "Sketch (Color)",
              "None"
            ],
            "ui": {
              "section": "additional",
              "order": 8
            }
          },
          "contrast": {
            "type": "number",
            "title": "Contrast",
            "description": "Contrast level for the generated image",
            "minimum": 0,
            "maximum": 2,
            "ui": {
              "section": "additional",
              "order": 9
            }
          },
          "controlnets": {
            "type": "array",
            "title": "ControlNets",
            "description": "Array of ControlNet configurations for guided generation",
            "ui": {
              "section": "controlnets",
              "order": 1
            },
            "items": {
              "type": "object",
              "properties": {
                "initImageId": {
                  "type": "string",
                  "title": "Init Image ID",
                  "description": "ID of the control image"
                },
                "initImageType": {
                  "type": "string",
                  "title": "Init Image Type",
                  "description": "Type of initialization image",
                  "enum": [
                    "GENERATED",
                    "UPLOADED"
                  ],
                  "enumNames": [
                    "Generated",
                    "Uploaded"
                  ]
                },
                "preprocessorId": {
                  "type": "integer",
                  "title": "Preprocessor ID",
                  "description": "ID of the preprocessor to use (67: Style, 133: Character, 182: Content)"
                },
                "strengthType": {
                  "type": "string",
                  "title": "Strength Type",
                  "description": "Strength level of ControlNet influence",
                  "enum": [
                    "Low",
                    "Mid",
                    "High",
                    "Ultra",
                    "Max"
                  ],
                  "default": "Mid"
                },
                "weight": {
                  "type": "number",
                  "title": "Weight",
                  "description": "Weight of ControlNet influence (0-1)",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.5
                }
              }
            }
          },
          "imagePrompts": {
            "type": "array",
            "title": "Image Prompts",
            "description": "Array of image prompts for visual guidance",
            "ui": {
              "section": "controlnets",
              "order": 2
            },
            "items": {
              "type": "object",
              "properties": {
                "imageId": {
                  "type": "string",
                  "title": "Image ID",
                  "description": "ID of the uploaded image to use as prompt"
                },
                "weight": {
                  "type": "number",
                  "title": "Weight",
                  "description": "Weight of image prompt influence (0-1)",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.5
                }
              }
            }
          },
          "upscaleRatio": {
            "type": "number",
            "title": "Upscale Ratio",
            "description": "Upscale ratio for output image (Enterprise Only)",
            "minimum": 1,
            "maximum": 4,
            "ui": {
              "section": "Advanced",
              "group": "Additional Settings",
              "order": 12
            }
          },
          "generationTimeout": {
            "type": "integer",
            "title": "Generation Timeout",
            "description": "Timeout in seconds for generation to complete",
            "minimum": 30,
            "maximum": 600,
            "ui": {
              "section": "Advanced",
              "group": "Additional Settings",
              "order": 13
            }
          }
        }
      },
      "result_schema": {
        "type": "object",
        "properties": {
          "generation_id": {
            "type": "string",
            "description": "ID of the generation job"
          },
          "poll_attempts": {
            "type": "integer",
            "description": "Number of polling attempts until completion"
          },
          "elapsed_seconds": {
            "type": "number",
            "description": "Time taken to complete generation"
          },
          "generated_images": {
            "type": "array",
            "description": "Array of generated images from Leonardo API",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Image ID"
                },
                "url": {
                  "type": "string",
                  "format": "uri",
                  "description": "CDN URL to the generated image"
                },
                "nsfw": {
                  "type": "boolean",
                  "description": "Whether image was flagged as NSFW"
                }
              }
            }
          },
          "downloaded_files": {
            "type": "array",
            "description": "Array of downloaded files stored locally",
            "items": {
              "type": "object",
              "properties": {
                "filename": {
                  "type": "string",
                  "description": "Local filename (e.g., leonardo_0.png)"
                },
                "file_size": {
                  "type": "integer",
                  "description": "File size in bytes"
                },
                "checksum": {
                  "type": "string",
                  "description": "SHA256 checksum of the file"
                },
                "virtual_path": {
                  "type": "string",
                  "description": "Virtual path for API access (e.g., /orgs/.../instances/.../leonardo_0.png)"
                },
                "source_url": {
                  "type": "string",
                  "format": "uri",
                  "description": "Original CDN URL the file was downloaded from"
                },
                "index": {
                  "type": "integer",
                  "description": "Index of this file in the generation"
                },
                "has_thumbnail": {
                  "type": "boolean",
                  "description": "Whether a thumbnail was generated"
                },
                "thumbnail_path": {
                  "type": "string",
                  "description": "Virtual path to the thumbnail image"
                }
              }
            }
          }
        }
      },
      "polling": {
        "enabled": true,
        "generation_id_path": "$.sdGenerationJob.generationId",
        "status_endpoint": "/generations/{generationId}",
        "status_path": "$.generations_by_pk.status",
        "complete_when": "COMPLETE",
        "result_path": "$.generations_by_pk.generated_images",
        "interval_ms": 2000,
        "max_attempts": 60,
        "timeout_seconds": 120
      },
      "post_processing": {
        "download_files": {
          "source_path": "$.generated_images[*].url",
          "filename_pattern": "leonardo_{uuid}.png",
          "timeout_seconds": 60,
          "max_file_size_mb": 50
        }
      },
      "output_view": {
        "type": "media_grid",
        "source": "downloaded_files",
