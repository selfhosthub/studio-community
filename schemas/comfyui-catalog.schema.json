{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/selfhosthub/studio-community/main/schemas/comfyui-catalog.schema.json",
  "title": "Studio ComfyUI Catalog",
  "description": "Index of all ComfyUI workflows in native ComfyUI API format.",
  "type": "object",
  "required": ["version", "comfyui"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "comfyui": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/comfyuiEntry"
      }
    }
  },
  "$defs": {
    "comfyuiEntry": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "version",
        "tier",
        "category",
        "description",
        "author",
        "download_url"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "display_name": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "tier": {
          "type": "string",
          "enum": ["basic", "plus"]
        },
        "category": {
          "type": "string",
          "examples": ["getting-started", "image-generation", "inpainting"]
        },
        "description": {
          "type": "string",
          "maxLength": 300
        },
        "author": {
          "type": "string"
        },
        "download_url": {
          "type": "string",
          "format": "uri"
        },
        "requires_token": {
          "type": "boolean",
          "default": false
        },
        "status": {
          "type": "string",
          "description": "Release status of this catalog entry.",
          "enum": ["dev", "released"]
        }
      }
    }
  }
}
