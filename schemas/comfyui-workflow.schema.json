{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/selfhosthub/studio-community/main/schemas/comfyui-workflow.schema.json",
  "title": "Studio ComfyUI Workflow",
  "description": "A ComfyUI workflow definition. Core metadata is validated; native ComfyUI API-format fields are allowed via additionalProperties.",
  "type": "object",
  "required": ["name", "description", "version", "author"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "author": {
      "type": "string"
    }
  }
}
