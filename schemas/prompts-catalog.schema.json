{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/selfhosthub/studio-community/main/schemas/prompts-catalog.schema.json",
  "title": "Studio Prompts Catalog",
  "description": "Index of all prompt templates. Full prompt definitions (chunks and variables) live in individual files referenced by the path field.",
  "type": "object",
  "required": ["version", "prompts"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "prompts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/promptEntry"
      }
    }
  },
  "$defs": {
    "promptEntry": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "version",
        "tier",
        "category",
        "description",
        "author",
        "download_url"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "examples": ["shs-news-narrator", "shs-scene-description"]
        },
        "display_name": {
          "type": "string",
          "examples": ["News Story Narrator", "Scene Description Generator"]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "tier": {
          "type": "string",
          "enum": ["basic", "plus"]
        },
        "category": {
          "type": "string",
          "description": "Prompt category for filtering.",
          "examples": ["story_generation", "scene_description", "summarization", "classification"]
        },
        "description": {
          "type": "string",
          "maxLength": 300
        },
        "author": {
          "type": "string"
        },
        "download_url": {
          "type": "string",
          "format": "uri"
        },
        "path": {
          "type": "string",
          "description": "Relative path to the prompt JSON file within studio-cat."
        },
        "status": {
          "type": "string",
          "description": "Release status of this catalog entry.",
          "enum": ["dev", "released"]
        }
      }
    },
    "promptChunk": {
      "type": "object",
      "required": ["text", "order", "role"],
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string",
          "description": "Prompt text. May contain {{ variable_name }} template expressions."
        },
        "variable": {
          "type": ["string", "null"],
          "description": "Variable name this chunk is associated with. Null for static text chunks."
        },
        "order": {
          "type": "integer",
          "description": "Display/assembly order. Lower = earlier in the prompt.",
          "minimum": 0
        },
        "role": {
          "type": "string",
          "description": "Chat message role for this chunk.",
          "enum": ["system", "user", "assistant"]
        }
      }
    },
    "promptVariable": {
      "type": "object",
      "required": ["name", "label", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Variable identifier. Must match {{ name }} references in chunks."
        },
        "label": {
          "type": "string",
          "description": "Human-readable label shown in the form."
        },
        "type": {
          "type": "string",
          "description": "Variable type. 'enum' renders as a dropdown, 'string' as a text field.",
          "enum": ["string", "enum"]
        },
        "options": {
          "type": ["array", "null"],
          "description": "Available options for enum-type variables. Null for string type.",
          "items": {
            "type": "string"
          }
        },
        "default": {
          "type": ["string", "null"],
          "description": "Default value. Null if no default."
        }
      }
    }
  }
}
