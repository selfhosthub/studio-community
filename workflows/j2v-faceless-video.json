{
  "name": "Faceless Video (API Edition)",
  "description": "Turn a news article into a narrated video using Leonardo AI images, OpenAI TTS narration, and JSON2Video rendering.",
  "version": "1.0.0",
  "author": "SelfHostHub",
  "requires": [
    "openai",
    "leonardo",
    "json2video",
    "core",
    "youtube"
  ],
  "prompts": [
    {
      "marketplace_slug": "shs-story-generator",
      "used_by_step": "generate_story"
    },
    {
      "marketplace_slug": "shs-scene-designer",
      "used_by_step": "generate_scene_content"
    }
  ],
  "steps": {
    "generate_story": {
      "name": "Generate Story",
      "description": "Generate a narrated story from the article (via prompt template)",
      "type": "task",
      "depends_on": [],
      "ui_config": {
        "position": {
          "x": 400,
          "y": 138
        }
      },
      "job": {
        "service_type": "ai",
        "provider_id": "openai",
        "service_id": "openai.openai_chat",
        "parameters": {
          "model": "gpt-4o",
          "messages": [],
          "temperature": 0.1,
          "max_tokens": 1000
        }
      },
      "input_mappings": {
        "messages": {
          "mappingType": "prompt",
          "promptSlug": "shs-story-generator"
        },
        "_prompt_variable:language": {
          "mappingType": "mapped",
          "stepId": "__instance_form__",
          "outputField": "subtitles_language"
        }
      },
      "timeout": 60,
      "outputs": {
        "response": {
          "path": "choices[0].message.content",
          "type": "string"
        }
      }
    },
    "generate_scene_content": {
      "name": "Generate Scene Content",
      "description": "Generate scenes with narration and image prompts (via prompt)",
      "type": "task",
      "depends_on": [
        "generate_story"
      ],
      "ui_config": {
        "position": {
          "x": 700,
          "y": 134
        }
      },
      "job": {
        "service_type": "ai",
        "provider_id": "openai",
        "service_id": "openai.openai_chat",
        "parameters": {
          "model": "gpt-4o",
          "messages": [],
          "temperature": 0.1,
          "max_tokens": 4000,
          "response_format": {
            "type": "json_object"
          }
        }
      },
      "input_mappings": {
        "messages": {
          "mappingType": "prompt",
          "promptSlug": "shs-scene-designer"
        },
        "_prompt_variable:story_text": {
          "mappingType": "mapped",
          "stepId": "generate_story",
          "outputField": "response"
        },
        "_prompt_variable:language": {
          "mappingType": "mapped",
          "stepId": "__instance_form__",
          "outputField": "subtitles_language"
        }
      },
      "timeout": 120,
      "outputs": {
        "scenes": {
          "path": "choices[0].message.content.scenes",
          "type": "array",
          "description": "Array of scene objects with narration and image_prompts"
        },
        "image_prompts": {
          "path": "choices[0].message.content.image_prompts",
          "type": "array",
          "description": "Flat array of all image prompts across all scenes"
        },
        "narrations": {
          "path": "choices[0].message.content.narrations",
          "type": "array",
          "description": "Flat array of all narration texts, one per scene"
        }
      }
    },
    "generate_images": {
      "name": "Generate Images",
      "description": "Generate illustrations for each image prompt using Leonardo AI",
      "type": "task",
      "depends_on": [
        "generate_scene_content"
      ],
      "ui_config": {
        "position": {
          "x": 1000,
          "y": 40
        }
      },
      "iteration_config": {
        "enabled": true,
        "source_step_id": "generate_scene_content",
        "source_output_field": "image_prompts",
        "target_parameter": "prompt",
        "execution_mode": "sequential"
      },
      "job": {
        "service_type": "ai",
        "provider_id": "leonardo",
        "service_id": "leonardo.text_to_image",
        "parameters": {
          "prompt": "{{ generate_scene_content.image_prompts[*] }}",
          "width": 1024,
          "height": 576,
          "num_images": 1,
          "modelId": "1e60896f-3c26-4296-8ecc-53e2afecc132"
        }
      },
      "input_mappings": {
        "prompt": {
          "mappingType": "mapped",
          "stepId": "generate_scene_content",
          "outputField": "image_prompts"
        },
        "modelId": {
          "mappingType": "form",
          "formField": "modelId"
        },
        "width": {
          "mappingType": "form",
          "formField": "image_width"
        },
        "height": {
          "mappingType": "form",
          "formField": "image_height"
        }
      },
      "timeout": 300,
      "outputs": {
        "downloaded_files": {
          "path": "downloaded_files",
          "type": "array"
        }
      }
    },
    "generate_narration": {
      "name": "Generate Narration (OpenAI TTS)",
      "description": "Generate TTS audio for each scene narration using OpenAI",
      "type": "task",
      "depends_on": [
        "generate_scene_content"
      ],
      "ui_config": {
        "position": {
          "x": 1000,
          "y": 228
        }
      },
      "iteration_config": {
        "enabled": true,
        "source_step_id": "generate_scene_content",
        "source_output_field": "narrations",
        "target_parameter": "input",
        "execution_mode": "sequential"
      },
      "job": {
        "service_type": "ai",
        "provider_id": "openai",
        "service_id": "openai.openai_tts",
        "parameters": {
          "input": "{{ generate_scene_content.narrations[*] }}",
          "model": "gpt-4o-mini-tts",
          "voice": "cedar",
          "instructions": "Speak in a clear, engaging news narrator voice. Maintain a steady, informative tone."
        }
      },
      "input_mappings": {
        "input": {
          "mappingType": "mapped",
          "stepId": "generate_scene_content",
          "outputField": "narrations"
        },
        "voice": {
          "mappingType": "form",
          "formField": "voice"
        },
        "language": {
          "mappingType": "mapped",
          "stepId": "__instance_form__",
          "outputField": "subtitles_language"
        }
      },
      "timeout": 300,
      "outputs": {
        "duration_seconds": {
          "path": "duration_seconds",
          "type": "number"
        },
        "storage_url": {
          "path": "storage_url",
          "type": "string"
        }
      }
    },
    "render_video": {
      "name": "Render Video",
      "description": "Submit video render job to JSON2Video with images and audio",
      "type": "task",
      "depends_on": [
        "generate_images",
        "generate_narration"
      ],
      "ui_config": {
        "position": {
          "x": 1300,
          "y": 146
        }
      },
      "job": {
        "service_type": "ai",
        "provider_id": "json2video",
        "service_id": "json2video.j2v_render",
        "parameters": {
          "cache": true,
          "draft": false,
          "width": 1920,
          "height": 1080,
          "quality": "high",
          "elements": [
            {
              "type": "subtitles",
              "language": "en",
              "settings": {
                "font-family": "Luckiest Guy"
              }
            }
          ],
          "scenes": [
            {
              "type": "scene_group",
              "scene_count": "{{ generate_scene_content.scene_count }}",
              "elements": [
                {
                  "type": "image",
                  "src": "{{ generate_images.downloaded_files }}",
                  "count": "{{ generate_scene_content.prompts_per_scene }}",
                  "duration": -1,
                  "resize": "cover"
                },
                {
                  "type": "audio",
                  "src": "{{ generate_narration.storage_url }}",
                  "count": 1,
                  "durations": "{{ generate_narration.duration_seconds }}"
                }
              ]
            }
          ]
        }
      },
      "input_mappings": {
        "scenes[0].scene_count": {
          "mappingType": "mapped",
          "stepId": "__instance_form__",
          "outputField": "scene_count"
        },
        "elements[0].language": {
          "mappingType": "form",
          "formField": "subtitles_language"
        }
      },
      "timeout": 120,
      "outputs": {
        "success": {
          "path": "success",
          "description": "Whether the request was accepted",
          "type": "boolean"
        },
        "project": {
          "path": "project",
          "description": "Project ID for tracking the render job",
          "type": "string"
        },
        "status_url": {
          "path": "status_url",
          "type": "string",
          "description": "URL to check video render status"
        },
        "timestamp": {
          "path": "timestamp",
          "description": "Timestamp when the job was created",
          "type": "string"
        },
        "project_id": {
          "path": "project",
          "type": "string",
          "description": "JSON2Video project ID"
        }
      }
    },
    "wait_for_video": {
      "name": "Wait for Video",
      "description": "Poll until video generation is complete",
      "type": "task",
      "depends_on": [
        "render_video"
      ],
      "ui_config": {
        "position": {
          "x": 1600,
          "y": 154
        }
      },
      "job": {
        "service_type": "flow",
        "provider_id": "core",
        "credential_provider_id": "json2video",
        "service_id": "core.poll_service",
        "auth_config": {
          "type": "header",
          "header": "x-api-key"
        },
        "parameters": {
          "url": "{{ render_video.status_url }}",
          "method": "GET",
          "interval_seconds": 10,
          "max_attempts": 60,
          "success_codes": [
            200
          ],
          "fail_codes": [
            400,
            401,
            500
          ],
          "success_condition": "success == true AND movie.status == \"done\"",
          "failure_condition": "movie.status == \"error\""
        }
      },
      "input_mappings": {
        "url": {
          "mappingType": "mapped",
          "stepId": "render_video",
          "outputField": "status_url"
        }
      },
      "timeout": 600,
      "outputs": {
        "video_url": {
          "path": "movie.url",
          "type": "string",
          "description": "URL of the completed video"
        },
        "status": {
          "path": "movie.status",
          "type": "string",
          "description": "Final render status"
        }
      },
      "output_forwarding": {
        "enabled": true,
        "mode": "selected",
        "selected_fields": [
          "project_id"
        ]
      }
    },
    "get_video": {
      "name": "Get Video",
      "description": "Retrieve the final video details and download URL",
      "type": "task",
      "depends_on": [
        "wait_for_video"
      ],
      "ui_config": {
        "position": {
          "x": 1900,
          "y": 146
        }
      },
      "job": {
        "service_type": "ai",
        "provider_id": "json2video",
        "service_id": "json2video.j2v_get_video",
        "parameters": {
          "project": ""
        }
      },
      "input_mappings": {
        "project": {
          "mappingType": "mapped",
          "stepId": "wait_for_video",
          "outputField": "project_id"
        }
      },
      "timeout": 30,
      "outputs": {
        "success": {
          "path": "success",
          "description": "Whether the API request was successful",
          "type": "boolean"
        },
        "movie": {
          "path": "movie",
          "description": "Video render job details",
          "type": "object"
        },
        "remaining_quota": {
          "path": "remaining_quota",
          "description": "Your account's remaining API credits",
          "type": "object"
        },
        "video_url": {
          "path": "movie.url",
          "type": "string",
          "description": "Download URL of the video"
        },
        "duration": {
          "path": "movie.duration",
          "type": "number",
          "description": "Video duration in seconds"
        },
        "size": {
          "path": "movie.size",
          "type": "number",
          "description": "Video file size in bytes"
        }
      }
    },
    "upload_to_youtube": {
      "name": "Upload to YouTube",
      "description": "Upload the rendered video to YouTube",
      "type": "task",
      "trigger_type": "manual",
      "depends_on": [
        "get_video"
      ],
      "ui_config": {
        "position": {
          "x": 2200,
          "y": 154
        }
      },
      "job": {
        "service_type": "SOCIAL_MEDIA",
        "provider_id": "youtube",
        "service_id": "youtube.youtube_upload_video",
        "parameters": {
          "title": "Untitled Video",
          "description": "",
          "categoryId": "22",
          "privacyStatus": "private",
          "madeForKids": false,
          "body_source_url": "{{ get_video.video_url }}",
          "content_type": "video/mp4"
        }
      },
      "input_mappings": {
        "body_source_url": {
          "mappingType": "mapped",
          "stepId": "get_video",
          "outputField": "video_url"
        }
      },
      "timeout": 600,
      "outputs": {
        "video_id": {
          "path": "id",
          "type": "string"
        },
        "upload_status": {
          "path": "status.uploadStatus",
          "type": "string"
        }
      }
    }
  },
